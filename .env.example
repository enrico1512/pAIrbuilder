# ===== Database =====
# Postgres connection string (Neon, Supabase, Replit DB, Postgres locale)
DATABASE_URL=postgresql://user:password@host:5432/pairbuilder
DATABASE_SSL=true

# ===== Auth =====
SESSION_SECRET=cambia-questo-con-una-stringa-lunga-casuale
BCRYPT_ROUNDS=12

# ===== AI =====
GEMINI_API_KEY=
OPENAI_API_KEY=
# Anthropic Claude — ultimo fallback dopo Gemini + OpenAI.
# Crea la chiave su https://console.anthropic.com/settings/keys
# (richiede credito pre-paid: min $5).
ANTHROPIC_API_KEY=
GOOGLE_CLOUD_VISION_API_KEY=

# ===== Server =====
PORT=3000
NODE_ENV=development
DISABLE_HMR=false
# APP_URL: dove gira l'app (per link self-referential / callback).
# In locale lasciare vuoto: il server usa http://localhost:PORT.
# Su Replit/Cloud Run viene iniettato automaticamente.
APP_URL=
