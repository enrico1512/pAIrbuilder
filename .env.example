# ===== Database =====
# Postgres connection string (Neon, Supabase, Replit DB, Postgres locale)
DATABASE_URL=postgresql://user:password@host:5432/pairbuilder
DATABASE_SSL=true

# ===== Auth =====
SESSION_SECRET=cambia-questo-con-una-stringa-lunga-casuale
BCRYPT_ROUNDS=12

# ===== AI =====
# Chain di estrazione: Anthropic (primario) → OpenAI → Gemini.
# Due configurazioni alternative:
#
# (A) GATEWAY (consigliato in produzione): UNA sola chiave OpenRouter per
#     tutti e 3 i provider. Una sola fattura, una sola dashboard. Markup
#     ~5% sui modelli premium.
#     - Crea account su https://openrouter.ai/
#     - Genera chiave sk-or-v1-... e mettila sotto
#     - GEMINI/OPENAI/ANTHROPIC_API_KEY possono restare vuote
OPENROUTER_API_KEY=
# Base URL OpenRouter (di default https://openrouter.ai/api/v1, raramente
# da cambiare).
OPENROUTER_BASE_URL=
#
# (B) PROVIDER DIRETTI: 3 chiavi separate, 3 fatture, 3 dashboard. Utile
#     in dev locale con account personali.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OpenAI Vision OCR (opzionale, fallback su PDF illeggibili)
GOOGLE_CLOUD_VISION_API_KEY=

# Override avanzato: cambia l'endpoint OpenAI (es. proxy aziendale).
# Ignorato se OPENROUTER_API_KEY e' settata.
OPENAI_BASE_URL=

# ===== Server =====
PORT=3000
NODE_ENV=development
DISABLE_HMR=false
# APP_URL: dove gira l'app (per link self-referential / callback).
# In locale lasciare vuoto: il server usa http://localhost:PORT.
# Su Replit/Cloud Run viene iniettato automaticamente.
# IMPORTANTE: in produzione setta al dominio finale (es.
# https://pairbuilder.ambrosiavino.com): i link nelle email di verifica e
# reset password si costruiscono da qui.
APP_URL=

# ===== Email transazionali (Resend) =====
# Resend.com → 3.000 mail/mese gratis, setup 1 chiave.
# Se non settata: in dev le email vengono loggate in console (utile per
# leggere il token di verifica/reset durante lo sviluppo locale).
RESEND_API_KEY=
# From-address che apparira' come mittente. Deve essere un dominio
# verificato su Resend (DKIM/SPF). Se vuoto, default in codice:
# "pAIrbuilder <support@ambrosiavino.com>". Override qui solo se servisse
# un altro mittente (staging, dev, ecc).
RESEND_FROM_EMAIL=

# ===== Anti-bot (Cloudflare Turnstile) =====
# https://www.cloudflare.com/products/turnstile/ → free, privacy-friendly.
# Servono 2 chiavi dalla dashboard Cloudflare: site key (pubblica, esposta
# al browser) e secret key (server-side).
# Se le chiavi NON sono settate: il widget non viene mostrato e il server
# accetta le request senza verifica captcha (modalita' dev).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
