# ===== Database =====
# Postgres connection string (Neon, Supabase, Replit DB, Postgres locale)
DATABASE_URL=postgresql://user:password@host:5432/pairbuilder
DATABASE_SSL=true

# ===== Auth =====
SESSION_SECRET=cambia-questo-con-una-stringa-lunga-casuale
BCRYPT_ROUNDS=12

# ===== AI =====
# Chain attuale di estrazione: Anthropic (primario) → OpenAI → Gemini.
GEMINI_API_KEY=
OPENAI_API_KEY=
# Anthropic Claude — provider PRIMARIO per estrazione menu (output 64k).
# Crea la chiave su https://console.anthropic.com/settings/keys
# (richiede credito pre-paid: min $5).
ANTHROPIC_API_KEY=
GOOGLE_CLOUD_VISION_API_KEY=

# ===== Gateway aggregator (opzionale) =====
# Per indirizzare il traffico AI verso un aggregator (OpenRouter, Vercel
# AI Gateway, Portkey) senza modificare il codice. Lasciare vuoti per
# colpire i provider diretti.
#
# Esempio OpenRouter (https://openrouter.ai/):
#   ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   (con ANTHROPIC_API_KEY e OPENAI_API_KEY = stessa chiave OpenRouter)
#
# NOTA: cambiando provider verifica i nomi modello — OpenRouter usa
# alias come "anthropic/claude-sonnet-4-5", non "claude-sonnet-4-6".
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=

# ===== Server =====
PORT=3000
NODE_ENV=development
DISABLE_HMR=false
# APP_URL: dove gira l'app (per link self-referential / callback).
# In locale lasciare vuoto: il server usa http://localhost:PORT.
# Su Replit/Cloud Run viene iniettato automaticamente.
APP_URL=
